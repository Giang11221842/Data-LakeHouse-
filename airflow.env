# Java & PySpark — must be explicit so every Celery worker subprocess can find the JVM
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
PYSPARK_PYTHON=/usr/local/bin/python3
PYSPARK_DRIVER_PYTHON=/usr/local/bin/python3

AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://postgres:postgres@postgres:5432/airflow_reddit
# Reduced from 4 → 2 to prevent multiple concurrent Spark sessions from causing OOM.
# Each Spark session consumes ~8 GB (4g driver + 4g executor); 2 sessions = ~16 GB max.
AIRFLOW__CELERY__WORKER_CONCURRENCY=2
AIRFLOW__CELERY__WORKER_PREFETCH_MULTIPLIER=1
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@postgres:5432/airflow_reddit
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW__WEBSERVER__SECRET_KEY=taxi_airflow_shared_secret_key_2026
AIRFLOW__CORE__LOGGING_LEVEL=INFO
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__SCHEDULER__TASK_INSTANCE_HEARTBEAT_SEC=30
# Increased from 1800 (30 min) → 7200 (2 h) to accommodate long-running Spark jobs.
# The previous 30-min limit caused the scheduler to mark Spark tasks as zombies mid-run.
AIRFLOW__SCHEDULER__TASK_INSTANCE_HEARTBEAT_TIMEOUT=7200
AIRFLOW__SCHEDULER__TASK_INSTANCE_HEARTBEAT_TIMEOUT_DETECTION_INTERVAL=60
AIRFLOW__SCHEDULER__TASK_QUEUED_TIMEOUT=7200
AIRFLOW__SCHEDULER__TASK_QUEUED_TIMEOUT_CHECK_INTERVAL=120
AIRFLOW__METRICS__STATSD_ON=True
AIRFLOW__METRICS__STATSD_HOST=statsd-exporter
AIRFLOW__METRICS__STATSD_PORT=9125
AIRFLOW__METRICS__STATSD_PREFIX=airflow
PYTHONPATH=/opt/airflow
